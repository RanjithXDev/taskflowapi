{
"compilerOptions": {
"target": "ES2020",
"module": "commonjs",
"rootDir": "./src",
"outDir": "./dist",
"strict": true,
"esModuleInterop": true,
"moduleResolution": "node",
"baseUrl": ".",
"paths": {
"@/*": ["src/*"]
},
"skipLibCheck": true
},
"include": [
"src/**/*"
],
"exclude": [
"node_modules",
"tests",
"**/*.test.ts"
]
}
