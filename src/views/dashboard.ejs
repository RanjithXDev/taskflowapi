<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>TaskFlow Dashboard</title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>

  <main class="container">
    <header>
      <h1>TaskFlow Dashboard</h1>
      <p>Manage your projects, tasks, users, and activities in one place</p>
      
      <button id="logoutBtn" class="logout-btn"> Logout</button>
    </header>


    <div class="card-container">
      <!-- Users Card -->
      <div class="card card-users">
        <div class="card-content">
          <h3>Users</h3>
          <p>Manage system users, permissions, and account settings across your organization</p>
          <div class="card-meta">
            <span class="badge">Team Management</span>
          </div>
        </div>
        <a href="/users-ui" class="card-btn">View Users</a>
      </div>

      <!-- Projects Card -->
      <div class="card card-projects">
        <div class="card-content">
          <h3>Projects</h3>
          <p>Create, organize, and monitor your projects with detailed tracking and insights</p>
          <div class="card-meta">
            <span class="badge">Project Tracking</span>
          </div>
        </div>
        <a href="/projects-ui" class="card-btn">View Projects</a>
      </div>

      <!-- Tasks Card -->
      <div class="card card-tasks">
        <div class="card-content">
          <h3>Tasks</h3>
          <p>Track and organize project tasks with status, priority, and deadline management</p>
          <div class="card-meta">
            <span class="badge">Task Management</span>
          </div>
        </div>
        <a href="/tasks-ui" class="card-btn">View Tasks</a>
      </div>

      <!-- Comments Card -->
      <div class="card card-comments">
        <div class="card-content">
          <h3>Comments</h3>
          <p>Collaborate effectively through task discussions and team communication</p>
          <div class="card-meta">
            <span class="badge">Collaboration</span>
          </div>
        </div>
        <a href="/comments-ui" class="card-btn">View Comments</a>
      </div>
    </div>

    <footer class="footer">
      <p>TaskFlow © 2026 - Ranjith MV (G0180). </p>
    </footer>
  </main>

  <script src="/js/animations.js"></script>
  <script src="/js/dashboard.js"></script>

</body>
</html>