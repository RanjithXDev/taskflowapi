<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task Comments - TaskFlow</title>
  <link rel="stylesheet" href="/css/comments.css">
</head>
<body>

<div class="container">

  <header class="page-header">
    <div>
      <h1>Task Comments</h1>
      <p>Collaborate with your team through task discussions and feedback</p>
    </div>
    <a href="/dashboard" class="back-btn">Back to Dashboard</a>
  </header>

  <section class="card">
    <h2>Add New Comment</h2>

    <form class="form-grid" onsubmit="return false;">

      <div class="form-group full">
        <label for="content">Your Comment</label>
        <textarea id="content" placeholder="Write your comment..." required></textarea>
      </div>

      <div class="form-group">
        <label for="author">Comment Author</label>
        <select id="author" required></select>
      </div>

      <div class="form-group">
        <label for="task">Select Task</label>
        <select id="task" required></select>
      </div>

      <div class="form-group">
        <label for="parent">Reply To (Optional)</label>
        <select id="parent">
          <option value="">Top Level Comment</option>
        </select>
      </div>

      <div class="form-group full">
        <button id="createCommentBtn" class="primary-btn">Add Comment</button>
      </div>

    </form>
  </section>

  <section class="card">
    <h2>All Comments</h2>
    <div id="comments"></div>
  </section>

</div>

<script src="/js/animations.js"></script>
<script src="/js/comments.js"></script>
</body>
</html>