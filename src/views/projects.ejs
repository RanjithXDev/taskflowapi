<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Project Management - TaskFlow</title>
  <link rel="stylesheet" href="/css/project.css">
</head>
<body>

<div class="container">

  <header class="page-header">
    <div>
      <h1>Project Management</h1>
      <p>Create, organize, and manage all your projects in one centralized location</p>
    </div>
    <a href="/dashboard" class="back-btn">Back to Dashboard</a>
  </header>

  <section class="card">
    <h2>Create New Project</h2>

    <form class="form-grid" onsubmit="return false;">

      <div class="form-group full">
        <label for="name">Project Name</label>
        <input id="name" placeholder="Enter project name" type="text" required>
      </div>

      <div class="form-group full">
        <label for="description">Description</label>
        <textarea id="description" placeholder="Describe your project and its goals" required></textarea>
      </div>

      <div class="form-group">
        <label for="owner">Project Owner</label>
        <select id="owner" required></select>
      </div>

      <div class="form-group">
        <label for="status">Status</label>
        <select id="status" required>
          <option value="active">Active</option>
          <option value="completed">Completed</option>
          <option value="archived">Archived</option>
        </select>
      </div>

      <div class="form-group full">
        <label for="members">Team Members</label>
        <select id="members" multiple placeholder="Select team members"></select>
      </div>

      <div class="form-group full">
        <button id="createProjectBtn" class="primary-btn">
          Create Project
        </button>
      </div>

    </form>
  </section>

  <section class="card">
    <h2>My Projects</h2>
    <div id="projects" class="project-grid"></div>
  </section>

</div>

<script src="/js/animations.js"></script>
<script src="/js/project.js"></script>
</body>
</html>