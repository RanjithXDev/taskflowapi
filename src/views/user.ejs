<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Management - TaskFlow</title>
  <link rel="stylesheet" href="/css/user.css">
</head>
<body>

<div class="container">

  <header class="page-header">
    <div>
      <h1>User Management</h1>
      <p>Create, manage, and organize system users and their permissions</p>
    </div>
    <a href="/dashboard" class="back-btn">Back to Dashboard</a>
  </header>

  <!-- Create User Card -->
  <section class="card form-card">
    <h2>Create New User</h2>

    <form class="form-grid" onsubmit="return false;">

      <div class="form-group">
        <label for="name">Full Name</label>
        <input id="name" type="text" placeholder="Enter full name (2–50 chars)" required>
      </div>

      <div class="form-group">
        <label for="email">Email Address</label>
        <input id="email" type="email" placeholder="Enter email address" required>
      </div>

      <div class="form-group">
        <label for="password">Password</label>
        <input id="password" type="password" placeholder="Enter password (min 8 chars)" required>
      </div>

      <div class="form-group">
        <label for="role">User Role</label>
        <select id="role" required>
          <option value="user">User</option>
          <option value="admin">Admin</option>
        </select>
      </div>

      <div class="form-group full">
        <label for="avatarFile">Profile Avatar</label>
        <input id="avatarFile" type="file" accept="image/png, image/jpeg">
        <small style="color: #999; margin-top: 5px;">Optional - PNG or JPEG (Max 5MB)</small>
      </div>

      <div class="form-group full">
        <button id="createBtn" class="primary-btn">Create User</button>
      </div>

    </form>

    <div id="error" class="error-msg" style="display: none;"></div>
  </section>

  <!-- Users List -->
  <section class="card">
    <h2>All Users</h2>
    <div id="users" class="user-grid"></div>
  </section>

</div>

<script src="/js/animations.js"></script>
<script src="/js/user.js"></script>
</body>
</html>