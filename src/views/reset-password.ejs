<!DOCTYPE html>
<html>
<head>
  <title>Reset Password</title>
  <link rel="stylesheet" href="/css/main.css">
</head>

<body>

  <div class="auth-container">

    <h2>Reset Password</h2>

    <input
      type="password"
      id="password"
      placeholder="New Password"
      required
    />

    <button id="resetBtn">
      Reset Password
    </button>

    <p id="message"></p>

  </div>

  <script src="/js/reset-password.js"></script>

</body>
</html>